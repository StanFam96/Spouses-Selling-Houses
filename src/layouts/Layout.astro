---
import '../styles/global.css';
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Spouses Selling Houses</title>
  </head>
  <body class="min-h-screen bg-white font-sans text-slate-800">
    <nav class="border-b border-blue-100 bg-white shadow-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="flex items-center gap-2">
          <span class="text-2xl font-bold text-blue-700">Spouses Selling Houses</span>
        </a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/" class="text-slate-600 transition hover:text-blue-700">Home</a>
          <a href="/about" class="text-slate-600 transition hover:text-blue-700">About</a>
          <a href="/listings" class="text-slate-600 transition hover:text-blue-700">Listings</a>
          <a href="/contact" class="text-slate-600 transition hover:text-blue-700">Contact</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="bg-blue-900 text-white">
      <div class="mx-auto max-w-6xl px-4 py-10">
        <div class="grid gap-8 md:grid-cols-3">
          <div>
            <h3 class="mb-3 text-lg font-semibold">Spouses Selling Houses</h3>
            <p class="text-sm text-blue-200">Your trusted real estate partners.</p>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold">Quick Links</h3>
            <div class="flex flex-col gap-2 text-sm text-blue-200">
              <a href="/" class="transition hover:text-white">Home</a>
              <a href="/about" class="transition hover:text-white">About</a>
              <a href="/listings" class="transition hover:text-white">Listings</a>
              <a href="/contact" class="transition hover:text-white">Contact</a>
            </div>
          </div>
          <div>
            <h3 class="mb-3 text-lg font-semibold">Contact</h3>
            <p class="text-sm text-blue-200">555 Real Estate Ave.<br />Suite 100<br />(555) 123-4567</p>
          </div>
        </div>
        <div class="mt-8 border-t border-blue-800 pt-6 text-center text-sm text-blue-300">
          &copy; 2026 Spouses Selling Houses. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
