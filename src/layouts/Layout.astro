---
import '../styles/global.css';
const {
  title,
  description = 'Keith & Kathleen Stanley — Your trusted Long Island real estate partners. Let us help you buy or sell your home.',
  image = '/images/keith-kathleen.jpg',
} = Astro.props;
const siteName = 'Spouses Selling Houses';
const fullTitle = `${title} | ${siteName}`;
const url = Astro.url;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, url).href} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, url).href} />
  </head>
  <body class="min-h-screen bg-white font-sans text-slate-800">
    <nav class="border-b border-blue-100 bg-white shadow-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="flex items-center gap-2">
          <span class="text-2xl font-bold text-blue-700">Spouses Selling Houses</span>
        </a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/" class="text-slate-600 transition hover:text-blue-700">Home</a>
          <a href="/about" class="text-slate-600 transition hover:text-blue-700">About</a>
          <a href="/listings" class="text-slate-600 transition hover:text-blue-700">Listings</a>
          <a href="/contact" class="text-slate-600 transition hover:text-blue-700">Contact</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="bg-blue-900 text-white">
      <div class="mx-auto max-w-6xl px-4 py-10">
        <div class="flex flex-col items-center gap-6 md:flex-row md:items-start md:justify-between">
          <div class="text-center md:text-left">
            <img src="/images/signature-logo.png" alt="Signature Premier Properties" class="mx-auto mb-4 h-12 w-auto md:mx-0" />
            <p class="text-lg font-semibold">Keith & Kathleen Stanley</p>
            <p class="text-sm text-blue-200">Licensed Real Estate Salesperson</p>
            <p class="mt-1 text-sm text-blue-200">Affiliated with Signature Premier Properties</p>
          </div>
          <div class="text-center md:text-left">
            <h3 class="mb-3 text-lg font-semibold">Quick Links</h3>
            <div class="flex flex-col gap-2 text-sm text-blue-200">
              <a href="/" class="transition hover:text-white">Home</a>
              <a href="/about" class="transition hover:text-white">About</a>
              <a href="/listings" class="transition hover:text-white">Listings</a>
              <a href="/contact" class="transition hover:text-white">Contact</a>
            </div>
          </div>
          <div class="text-center md:text-left">
            <h3 class="mb-3 text-lg font-semibold">Contact</h3>
            <p class="text-sm text-blue-200">Based in Massapequa Park</p>
            <p class="mt-2 text-sm text-blue-200"><span class="font-medium text-white">Keith:</span> 516-582-7795<br />kstanley@signaturepremier.com</p>
            <p class="mt-2 text-sm text-blue-200"><span class="font-medium text-white">Kathleen:</span> 516-582-7653<br />kastanley@signaturepremier.com</p>
          </div>
        </div>
        <div class="mt-8 border-t border-blue-800 pt-6 text-center text-sm text-blue-300">
          <p class="mb-1">Equal Housing Opportunity</p>
          <p>&copy; 2026 Keith & Kathleen Stanley. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
