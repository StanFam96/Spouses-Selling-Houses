---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Get in touch with Keith & Kathleen Stanley. Based in Massapequa Park, serving all of Long Island. Call or email us today.">
  <section class="bg-blue-50 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h1 class="mb-4 text-4xl font-bold text-slate-800">Get in Touch</h1>
      <p class="text-lg text-slate-600">We'd love to hear from you. Reach out and let's find your dream home.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <form name="contact" method="POST" data-netlify="true" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="mb-1 block text-sm font-medium text-slate-700">Name</label>
              <input type="text" id="name" name="name" required class="w-full rounded-lg border border-blue-200 px-4 py-3 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="mb-1 block text-sm font-medium text-slate-700">Email</label>
              <input type="email" id="email" name="email" required class="w-full rounded-lg border border-blue-200 px-4 py-3 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" placeholder="you@example.com" />
            </div>
            <div>
              <label for="message" class="mb-1 block text-sm font-medium text-slate-700">Message</label>
              <textarea id="message" name="message" required rows="5" class="w-full rounded-lg border border-blue-200 px-4 py-3 text-sm outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-200" placeholder="How can we help?"></textarea>
            </div>
            <button type="submit" class="rounded-lg bg-blue-700 px-8 py-3 text-sm font-semibold text-white transition hover:bg-blue-800">Send Message</button>
          </form>
          <script>
            const msg = new URLSearchParams(window.location.search).get('message');
            const sanitize = (s) => s.replace(/[<>]/g, '');
            if (msg) document.getElementById('message').value = sanitize(msg);

            document.querySelector("form[name=contact]").addEventListener("submit", async (e) => {
              e.preventDefault();
              const form = e.currentTarget;
              const data = new URLSearchParams(new FormData(form));
              const res = await fetch("/__forms.html", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: data.toString(),
              });
              if (res.ok) {
                form.innerHTML = '<p class="text-green-600 font-semibold">Thanks! We\'ll be in touch.</p>';
              }
            });
          </script>
        </div>
        <div class="space-y-6">
          <div class="rounded-xl border border-blue-100 bg-blue-50 p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-800">Keith Stanley</h3>
            <p class="text-sm text-slate-600">516-582-7795<br />kstanley@signaturepremier.com</p>
          </div>
          <div class="rounded-xl border border-blue-100 bg-blue-50 p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-800">Kathleen Stanley</h3>
            <p class="text-sm text-slate-600">516-582-7653<br />kastanley@signaturepremier.com</p>
          </div>
          <div class="rounded-xl border border-blue-100 bg-blue-50 p-6">
            <h3 class="mb-3 text-lg font-semibold text-slate-800">Location</h3>
            <p class="text-sm text-slate-600">Based in Massapequa Park</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
