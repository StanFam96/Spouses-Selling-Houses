---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getListing, urlFor } from '../../utils/sanity';

const { id } = Astro.params;
const listing = await getListing(id!);

if (!listing) {
  return Astro.redirect('/listings');
}

const images = listing.images ?? [];
const heroImage = images[0];
const heroUrl = heroImage ? urlFor(heroImage).width(800).height(500).fit('crop').url() : null;
const interestHref = `/contact?message=${encodeURIComponent(`I am interested in ${listing.address} ($${listing.price.toLocaleString()}). Please send me more information.`)}`;
---
<Layout title={listing.address} description={`${listing.address} — ${listing.beds} bed, ${listing.baths} bath, ${listing.sqft.toLocaleString()} sqft — $${listing.price.toLocaleString()}. `} image={heroUrl}>
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4">
      <a href="/listings" class="mb-6 inline-flex items-center text-sm text-blue-600 hover:text-blue-800">&larr; Back to Listings</a>

      <div id="carousel" class="relative mb-8">
        {listing.status === 'sold' && (
          <div class="absolute left-4 top-4 z-10 rounded-lg bg-slate-700/90 px-4 py-2 text-sm font-bold uppercase tracking-wider text-white shadow-lg">Sold</div>
        )}
        <div class="flex h-80 items-center justify-center overflow-hidden rounded-2xl bg-slate-100 shadow-lg">
          {images.length > 0 ? (
            <div class="flex h-full w-full transition-transform duration-300" id="carousel-track" style="transform: translateX(0)">
              {images.map((img, i) => (
                <img src={urlFor(img).width(800).height(500).fit('crop').url()} alt={img.alt ?? listing.address} class="h-full w-full shrink-0 object-cover" data-index={i} />
              ))}
            </div>
          ) : (
            <span class="text-sm text-slate-400">No photos</span>
          )}
        </div>
        {images.length > 1 && (
          <>
            <button id="prev-btn" class="absolute left-3 top-1/2 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-slate-700 shadow transition hover:bg-white">&lsaquo;</button>
            <button id="next-btn" class="absolute right-3 top-1/2 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-slate-700 shadow transition hover:bg-white">&rsaquo;</button>
            <div class="mt-3 flex justify-center gap-2">
              {images.map((_, i) => (
                <button class="carousel-dot h-2 w-2 rounded-full bg-slate-300 transition hover:bg-slate-400" data-index={i}></button>
              ))}
            </div>
          </>
        )}
      </div>

      <h1 class="mb-2 text-3xl font-bold text-slate-800 md:text-4xl">{listing.address}</h1>
      <p class="mb-4 text-3xl font-bold text-blue-700">${listing.price.toLocaleString()}</p>
      <p class="mb-6 text-sm text-slate-500">{listing.beds} bed &bull; {listing.baths} bath &bull; {listing.sqft.toLocaleString()} sqft</p>
      {listing.description && <p class="mb-8 leading-relaxed text-slate-600">{listing.description}</p>}
      {listing.status === 'available' && (
        <a href={interestHref} class="inline-block rounded-lg bg-blue-700 px-8 py-4 text-lg font-semibold text-white shadow-lg transition hover:bg-blue-800">I am interested in this home</a>
      )}
    </div>
  </section>
</Layout>

<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll('.carousel-dot');
  if (track && dots.length) {
    let index = 0;
    function goTo(i) {
      index = i;
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, j) => {
        d.classList.toggle('bg-slate-600', j === index);
        d.classList.toggle('bg-slate-300', j !== index);
      });
    }
    prevBtn?.addEventListener('click', () => goTo(index > 0 ? index - 1 : dots.length - 1));
    nextBtn?.addEventListener('click', () => goTo(index < dots.length - 1 ? index + 1 : 0));
    dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.dataset.index))));
    goTo(0);
  }
</script>
