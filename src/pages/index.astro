---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <section class="bg-gradient-to-br from-blue-600 to-blue-800 py-24 text-white">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h1 class="mb-4 text-5xl font-bold md:text-6xl">Spouses Selling Houses</h1>
      <p class="mb-8 text-xl text-blue-100">Your dream home is just a conversation away.</p>
      <a href="/listings" class="inline-block rounded-lg bg-white px-8 py-3 text-lg font-semibold text-blue-700 shadow-lg transition hover:bg-blue-50">Browse Listings</a>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-12 text-center text-3xl font-bold text-slate-800">Why Choose Us?</h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-xl border border-blue-100 p-6 text-center shadow-sm">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-blue-100 text-2xl text-blue-700">🏠</div>
          <h3 class="mb-2 text-xl font-semibold text-slate-800">Local Experts</h3>
          <p class="text-sm text-slate-600">Deep knowledge of the neighborhoods you care about most.</p>
        </div>
        <div class="rounded-xl border border-blue-100 p-6 text-center shadow-sm">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-blue-100 text-2xl text-blue-700">🤝</div>
          <h3 class="mb-2 text-xl font-semibold text-slate-800">Personal Service</h3>
          <p class="text-sm text-slate-600">We treat every client like family from first handshake to closing day.</p>
        </div>
        <div class="rounded-xl border border-blue-100 p-6 text-center shadow-sm">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-blue-100 text-2xl text-blue-700">📈</div>
          <h3 class="mb-2 text-xl font-semibold text-slate-800">Proven Results</h3>
          <p class="text-sm text-slate-600">Hundreds of happy homeowners and counting.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
